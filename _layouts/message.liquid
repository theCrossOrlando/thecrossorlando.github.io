---
layout: default
---
{%- assign ext = file | split: "." | last | downcase -%}
{%- assign mime = "audio/mpeg" -%}
{%- if ext == "m4a" %}{%- assign mime = "audio/x-m4a" -%}{%- endif -%}
{%- assign speaker = podcast_author | default: "Ben Hoyer" -%}
{%- assign dparts = duration | split: ":" -%}

<p class="message-meta text-muted">{{ page.date | date: "%B %-d, %Y" }} &middot; {{ speaker }} &middot; {{ duration }}</p>

{% if scripture %}<p class="scripture">{% assign refs = scripture | split: ";" %}{% for ref in refs %}{%- assign r = ref | strip -%}<a href="https://www.biblegateway.com/passage/?search={{ r | url_encode }}&amp;version=ESV" target="_blank" rel="noopener">{{ r }}</a>{% unless forloop.last %}, {% endunless %}{% endfor %}</p>{% endif %}

{% if summary %}<p class="lead">{{ summary }}</p>{% endif %}

<audio controls preload="none" class="w-100">
  <source src="{{ file }}" type="{{ mime }}">
  Your browser doesn’t support the audio element. <a href="{{ file }}">Download the audio</a>.
</audio>

<p class="message-actions">
  Listen &amp; subscribe:
  {% if podcast.apple != "" %}<a href="{{ podcast.apple }}">Apple Podcasts</a> &middot; {% endif %}
  {% if podcast.spotify != "" %}<a href="{{ podcast.spotify }}">Spotify</a> &middot; {% endif %}
  <a href="{{ podcast.rss }}">RSS</a>
</p>

{% unless content == blank %}
<details class="transcript">
  <summary>Read transcript</summary>
  <p><small class="text-muted">Auto-generated from the audio — may contain errors.</small></p>
  {{ content }}
</details>
{% endunless %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "PodcastEpisode",
  "url": "{{ site_url }}{{ page.url }}",
  "name": {{ title | jsonify }},
  "datePublished": "{{ page.date | date: '%Y-%m-%d' }}",
  "description": {{ summary | default: title | jsonify }},
  {% if dparts.size == 2 %}"timeRequired": "PT{{ dparts[0] }}M{{ dparts[1] }}S",{% endif %}
  "associatedMedia": { "@type": "MediaObject", "contentUrl": "{{ file }}" },
  "partOfSeries": { "@type": "PodcastSeries", "name": {{ site_title | jsonify }}, "url": "{{ site_url }}/feed.xml" }
}
</script>

<script src="/js/messages.js"></script>
