{
  "name": "thecross",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "run-s build:html build:css build:js build:lyrics build:messages",
    "build:html": "eleventy",
    "build:css": "sass _css/style.scss:_site/css/style.css -I _css -I node_modules/bootstrap/scss -I node_modules/@fontsource -I node_modules/@fortawesome/fontawesome-free/scss --no-source-map --quiet-deps && postcss _site/css/style.css --replace --config postcss.config.js",
    "build:js": "esbuild _js/script.js --bundle --minify --format=iife --sourcemap --outfile=_site/js/script.js",
    "build:lyrics": "esbuild _js/lyrics.js --bundle --minify --format=esm --external:https://* --sourcemap --outfile=_site/js/lyrics.js",
    "build:messages": "terser node_modules/plyr/dist/plyr.min.js _js/messages.js --compress --mangle --output _site/js/messages.js",
    "dev": "run-p dev:css dev:js dev:serve",
    "dev:css": "sass --watch _css/style.scss:css/style.css -I _css -I node_modules/bootstrap/scss -I node_modules/@fontsource -I node_modules/@fortawesome/fontawesome-free/scss --quiet-deps",
    "dev:js": "onchange --initial \"_js/**/*.js\" -- run-s dev:js:script dev:js:lyrics dev:js:messages",
    "dev:js:script": "esbuild _js/script.js --bundle --format=iife --sourcemap --outfile=js/script.js",
    "dev:js:lyrics": "esbuild _js/lyrics.js --bundle --format=esm --external:https://* --sourcemap --outfile=js/lyrics.js",
    "dev:js:messages": "terser node_modules/plyr/dist/plyr.min.js _js/messages.js --output js/messages.js",
    "dev:serve": "eleventy --serve"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@fontsource/arvo": "^5.2.7",
    "@fontsource/cardo": "^5.2.8",
    "@fontsource/roboto": "^5.2.9",
    "@fortawesome/fontawesome-free": "^7.1.0",
    "@fullhuman/postcss-purgecss": "^7.0.0",
    "bootstrap": "^5.3.8",
    "cssnano": "^7.1.2",
    "esbuild": "^0.28.1",
    "html-minifier-terser": "^7.2.0",
    "masonry-layout": "^4.2.2",
    "npm-run-all2": "^9.0.2",
    "onchange": "^7.1.0",
    "plyr": "^3.8.4",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-discard-comments": "^8.0.1",
    "rss-parser": "^3.13.0",
    "sass": "^1.97.1",
    "terser": "^5.48.0"
  }
}
